<Window x:Class="MqttViewer.ImportTimeRangeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        ShowInTaskbar="False"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Title="{Binding [ImportRangeTitle]}">
    <Grid Margin="24" Width="440">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding [ImportRangeTitle]}"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4" />

        <TextBlock Grid.Row="1"
                   Text="{Binding [ImportRangeDescription]}"
                   TextWrapping="Wrap"
                   Opacity="0.8"
                   Margin="0,0,0,12" />

        <TextBlock Grid.Row="2"
                   x:Name="AvailableText"
                   TextWrapping="Wrap"
                   Opacity="0.7"
                   Margin="0,0,0,16" />

        <!-- Start -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Width="44"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Text="{Binding [ImportRangeStart]}" />
            <DatePicker x:Name="StartDatePicker"
                        Width="150"
                        Margin="0,0,8,0"
                        Style="{StaticResource MaterialDesignDatePicker}" />
            <materialDesign:TimePicker x:Name="StartTimePicker"
                                       Width="150"
                                       Is24Hours="True"
                                       Style="{StaticResource MaterialDesignTimePicker}" />
        </StackPanel>

        <!-- End -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,4">
            <TextBlock Width="44"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Text="{Binding [ImportRangeEnd]}" />
            <DatePicker x:Name="EndDatePicker"
                        Width="150"
                        Margin="0,0,8,0"
                        Style="{StaticResource MaterialDesignDatePicker}" />
            <materialDesign:TimePicker x:Name="EndTimePicker"
                                       Width="150"
                                       Is24Hours="True"
                                       Style="{StaticResource MaterialDesignTimePicker}" />
        </StackPanel>

        <TextBlock Grid.Row="5"
                   x:Name="ErrorText"
                   Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"
                   Margin="0,4,0,8"
                   Text="{Binding [ImportRangeInvalid]}" />

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="FullRangeButton"
                    Content="{Binding [ImportRangeFull]}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Margin="0,0,8,0"
                    Click="FullRangeButton_OnClick" />
            <Button x:Name="CancelButton"
                    Content="{Binding [ImportRangeCancel]}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Click="CancelButton_OnClick" />
            <Button x:Name="OkButton"
                    Content="{Binding [ImportRangeOk]}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    IsDefault="True"
                    Click="OkButton_OnClick" />
        </StackPanel>
    </Grid>
</Window>
